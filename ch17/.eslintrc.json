{
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "requireConfigFile": false,
    "sourceType": "module",
    "babelOptions": {
      "presets": ["@babel/preset-env", "@babel/preset-flow"]
    }
  },
  "env": {
    "node": true,
    "es6": true
  },
  "extends": ["eslint:recommended", "plugin:flowtype/recommended", "prettier"],
  "plugins": ["flowtype"],
  "rules": {
    "flowtype/no-types-missing-file-annotation": "off"
  }
}
